{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Voting Client",
      "request": "launch",
      "mainClass": "com.voting.client.VotingClientUI",
      "vmArgs": "--module-path \"${workspaceFolder}/lib/javafx\" --add-modules javafx.controls,javafx.fxml"
    },
    {
      "type": "java",
      "name": "Run Voting Server",
      "request": "launch",
      "mainClass": "com.voting.server.VotingServer"
    }
  ]
}
